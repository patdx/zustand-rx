{
  "private": true,
  "name": "@zustand-rx/workspace",
  "version": "2.1.0",
  "license": "MIT",
  "homepage": "https://github.com/patdx/zustand-rx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patdx/zustand-rx.git"
  },
  "type": "module",
  "scripts": {
    "build": "wireit",
    "clean": "rm -rf node_modules && rm -rf dist && rm -rf apps/zustand-rx-web/node_modules && rm -rf apps/zustand-rx-web/dist",
    "cz": "cz",
    "dev": "wireit",
    "preinstall": "npx only-allow pnpm",
    "lint": "wireit",
    "prepare": "husky",
    "preview": "wireit",
    "test": "wireit"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "sideEffects": false,
  "dependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "html-escaper": "3.0.3",
    "observable-hooks": "4.2.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rxjs": "7.8.2",
    "zustand": "4.5.7"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/preset-react": "7.29.7",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/js": "10.0.1",
    "@testing-library/react": "15.0.7",
    "@types/node": "22.19.19",
    "@types/react": "18.3.30",
    "@types/react-dom": "18.3.7",
    "@vitest/coverage-v8": "2.1.9",
    "@vitest/ui": "2.1.9",
    "astro": "4.16.19",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "10.4.1",
    "husky": "9.1.7",
    "jsdom": "26.1.0",
    "lint-staged": "15.5.2",
    "only-allow": "1.2.2",
    "prettier": "3.8.3",
    "prettier-package-json": "2.8.0",
    "shx": "0.4.0",
    "tslib": "2.8.1",
    "tsup": "8.5.1",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.12.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.1",
    "vite": "5.4.21",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "2.1.9",
    "wireit": "^0.14.9",
    "wrangler": "4.97.0"
  },
  "lint-staged": {
    "*.{js,ts,md}": "prettier --write",
    "package.json": "prettier-package-json --write"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "wireit": {
    "build": {
      "command": "cd libs/zustand-rx && tsup && cd ../.. && pnpm shx cp libs/zustand-rx/README.md dist/libs/zustand-rx/README.md && pnpm shx cp libs/zustand-rx/package.json dist/libs/zustand-rx/package.json && pnpm attw --pack dist/libs/zustand-rx",
      "files": [
        "libs/zustand-rx/src/**",
        "libs/zustand-rx/tsconfig.json",
        "libs/zustand-rx/README.md",
        "libs/zustand-rx/package.json",
        "tsconfig.base.json"
      ],
      "output": [
        "dist/libs/zustand-rx/**"
      ]
    },
    "test": {
      "command": "vitest run --config libs/zustand-rx/vite.config.ts",
      "files": [
        "libs/zustand-rx/src/**",
        "libs/zustand-rx/vite.config.ts"
      ],
      "output": [
        "coverage/libs/zustand-rx/**"
      ],
      "dependencies": [
        "build"
      ]
    },
    "lint": {
      "command": "eslint",
      "files": [
        "libs/zustand-rx/src/**",
        "apps/zustand-rx-web/**",
        "eslint.config.js"
      ]
    },
    "dev": {
      "command": "cd apps/zustand-rx-web && astro dev",
      "service": true,
      "files": [
        "apps/zustand-rx-web/**"
      ]
    },
    "preview": {
      "command": "cd apps/zustand-rx-web && astro preview",
      "service": true,
      "dependencies": [
        "build"
      ],
      "files": [
        "apps/zustand-rx-web/**",
        "dist/libs/zustand-rx/**"
      ]
    }
  }
}
