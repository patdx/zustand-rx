{
  "private": true,
  "name": "@zustand-rx/workspace",
  "version": "2.1.0",
  "license": "MIT",
  "homepage": "https://github.com/patdx/zustand-rx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patdx/zustand-rx.git"
  },
  "type": "module",
  "scripts": {
    "build": "wireit",
    "clean": "rm -rf node_modules && rm -rf dist && rm -rf apps/zustand-rx-web/node_modules && rm -rf apps/zustand-rx-web/dist",
    "dev": "wireit",
    "preinstall": "npx only-allow pnpm",
    "lint": "wireit",
    "prepare": "husky",
    "preview": "wireit",
    "test": "wireit"
  },
  "sideEffects": false,
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "10.4.1",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.7",
    "prettier": "3.8.3",
    "prettier-package-json": "2.8.0",
    "rxjs": "7.8.2",
    "tsup": "8.5.1",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.12.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vite": "7.3.5",
    "vitest": "4.1.8",
    "wireit": "^0.14.12",
    "wrangler": "4.97.0",
    "zustand": "5.0.14",
    "zustand3": "npm:zustand@3.7.2",
    "zustand4": "npm:zustand@4.5.7"
  },
  "lint-staged": {
    "*.{js,ts,md}": "prettier --write",
    "package.json": "prettier-package-json --write"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "wireit": {
    "build": {
      "command": "cd libs/zustand-rx && tsup && cd ../.. && cp libs/zustand-rx/README.md dist/libs/zustand-rx/README.md && cp libs/zustand-rx/package.json dist/libs/zustand-rx/package.json && pnpm attw --pack dist/libs/zustand-rx",
      "files": [
        "libs/zustand-rx/src/**",
        "libs/zustand-rx/tsconfig.json",
        "libs/zustand-rx/README.md",
        "libs/zustand-rx/package.json",
        "tsconfig.base.json"
      ],
      "output": [
        "dist/libs/zustand-rx/**"
      ]
    },
    "test": {
      "command": "vitest run --config libs/zustand-rx/vite.config.ts",
      "files": [
        "libs/zustand-rx/src/**",
        "libs/zustand-rx/vite.config.ts"
      ],
      "output": [
        "coverage/libs/zustand-rx/**"
      ],
      "dependencies": [
        "build"
      ]
    },
    "lint": {
      "command": "eslint",
      "files": [
        "libs/zustand-rx/src/**",
        "apps/zustand-rx-web/**",
        "eslint.config.js"
      ]
    },
    "dev": {
      "command": "cd apps/zustand-rx-web && astro dev",
      "service": true,
      "files": [
        "apps/zustand-rx-web/**"
      ]
    },
    "preview": {
      "command": "cd apps/zustand-rx-web && astro preview",
      "service": true,
      "dependencies": [
        "build"
      ],
      "files": [
        "apps/zustand-rx-web/**",
        "dist/libs/zustand-rx/**"
      ]
    }
  }
}
