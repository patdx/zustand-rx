{
  "root": true,
  "ignorePatterns": [
    "**/dist/**",
    "**/coverage/**",
    "**/node_modules/**",
    "**/public/**",
    "**/*.config.*",
    "**/*.d.ts"
  ],
  "plugins": ["@typescript-eslint"],
  "rules": {},
  "overrides": [
    {
      "files": ["*.ts", "*.tsx"],
      "extends": ["plugin:@typescript-eslint/recommended"]
    },
    {
      "files": ["*.js", "*.jsx"],
      "extends": ["eslint:recommended"]
    }
  ]
}
